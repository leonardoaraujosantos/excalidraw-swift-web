{
  "name": "excalidraw-web-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "build:libs": "pnpm -r --filter \"./packages/*\" --filter \"./server\" run build",
    "publish:libs": "pnpm -r --filter \"./packages/*\" --filter \"./server\" publish --access public"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "perfect-freehand": "^1.2.3",
    "roughjs": "^4.6.6"
  }
}
