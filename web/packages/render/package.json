{
  "name": "@cyberdynecorpai/render",
  "version": "0.1.0",
  "description": "Canvas2D scene renderer, rough.js drawables, and SVG/PNG export — ported from ExcalidrawRender.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@cyberdynecorpai/geometry": "workspace:*",
    "@cyberdynecorpai/math": "workspace:*",
    "@cyberdynecorpai/model": "workspace:*",
    "perfect-freehand": "^1.2.2",
    "roughjs": "^4.6.6"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  },
  "license": "MIT",
  "author": "Cyberdyne Corp AI",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leonardoaraujosantos/excalidraw-swift.git",
    "directory": "web/packages/render"
  },
  "homepage": "https://github.com/leonardoaraujosantos/excalidraw-swift#readme",
  "module": "./dist/index.js",
  "files": ["dist", "README.md"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
