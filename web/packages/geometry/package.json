{
  "name": "@cyberdynecorpai/geometry",
  "version": "0.1.0",
  "description": "Element-aware geometry — bounds, hit-testing, binding, snapping, culling — ported from ExcalidrawGeometry.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@cyberdynecorpai/math": "workspace:*",
    "@cyberdynecorpai/model": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  },
  "license": "MIT",
  "author": "Cyberdyne Corp AI",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leonardoaraujosantos/excalidraw-swift.git",
    "directory": "web/packages/geometry"
  },
  "homepage": "https://github.com/leonardoaraujosantos/excalidraw-swift#readme",
  "module": "./dist/index.js",
  "files": ["dist", "README.md"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
